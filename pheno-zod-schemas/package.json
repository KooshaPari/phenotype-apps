{
  "name": "@kooshapari/pheno-zod-schemas",
  "version": "0.1.0",
  "description": "Canonical Zod schemas for the pheno-* fleet. Mirrors pheno-pydantic-models domain model (User, WorklogEntry, Project) so TS and Python services validate the same wire contract.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "zod",
    "schema",
    "phenotype",
    "pheno",
    "validation",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^4.1.8"
  }
}
