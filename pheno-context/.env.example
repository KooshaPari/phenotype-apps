# ADR-036: OTLP substrate configuration for `pheno-context::init()`.
#
# The endpoint is read by `pheno_otel::init` (full OTLP export).
# `pheno_context::init` installs a stdout fmt subscriber and is a
# no-op with respect to OTLP today; it is kept on the same env var
# so consumers can switch by feature flag without changing deploys.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# `tracing-subscriber` EnvFilter directive (ADR-036).
# When unset, `pheno_context::init` defaults to `info`.
# RUST_LOG=pheno_context=debug,info
