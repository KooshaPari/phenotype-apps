#!/bin/bash
# Pre-commit hook for Phenotype projects
# Checks FR annotations, test file existence, formatting, linting, and file integrity

set -e

echo "рџ”Ќ Running pre-commit checks..."

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Configuration
MAX_FILE_SIZE_BYTES=$((10 * 1024 * 1024))  # 10 MB max per file
SECRET_PATTERNS=(
    '-----BEGIN PRIVATE KEY-----'
    '-----BEGIN EC PRIVATE KEY-----'
    '-----BEGIN RSA PRIVATE KEY-----'
    '-----BEGIN OPENSSH PRIVATE KEY-----'
    '-----BEGIN DSA PRIVATE KEY-----'
    'AKIA[0-9A-Z]{16}'                      # AWS Access Key
    'sk_live_[0-9a-zA-Z]+'                   # Stripe live secret
    'ghp_[0-9a-zA-Z]{36}'                   # GitHub PAT (legacy)
    'gho_[0-9a-zA-Z]{36}'                   # GitHub OAuth
    'github_pat_[0-9a-zA-Z]{36}'            # GitHub PAT (fine-grained)
    'xox[baprs]-[0-9a-zA-Z-]+'              # Slack tokens
)

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# Track errors
ERRORS=0

# Check 1: FR annotations in staged test files
echo "рџ“‹ Checking FR annotations in test files..."
TEST_FILES=$(echo "$STAGED_FILES" | grep -E '(_test\.rs|tests?/.*\.rs|\.test\.(ts|js|py|go))$' || true)

if [ -n "$TEST_FILES" ]; then
    for file in $TEST_FILES; do
        if [ -f "$file" ]; then
            # Check for FR annotation (supports Rust, TypeScript, Python, Go style comments)
            if ! grep -qE '(// FR:|// @FR|# FR:|# @FR|\* FR:|\* @FR|//fr |#fr )' "$file" 2>/dev/null; then
                echo -e "${YELLOW}вљ пёЏ  Warning: No FR annotation found in test file: $file${NC}"
                echo "   Add an annotation like: // FR: REQ-001 - Description"
                # Non-blocking warning for now
            fi
        fi
    done
fi

# Check 2: Test file exists for staged source files
echo "рџ“Ѓ Checking test file existence..."

for file in $STAGED_FILES; do
    case "$file" in
        *.rs)
            if [[ ! "$file" =~ ^tests?/ ]] && [[ ! "$file" =~ _test\.rs$ ]]; then
                # Check for corresponding test file
                basename=$(basename "$file" .rs)
                dir=$(dirname "$file")

                # Check various test file patterns
                if [ -f "${dir}/${basename}_test.rs" ] || \
                   [ -f "tests/${basename}.rs" ] || \
                   [ -f "tests/${dir}/${basename}.rs" ] || \
                   grep -q "#\[cfg(test)\]" "$file" 2>/dev/null || \
                   grep -q "#\[test\]" "$file" 2>/dev/null; then
                    : # Test file exists or inline tests present
                else
                    echo -e "${YELLOW}вљ пёЏ  No test file found for: $file${NC}"
                fi
            fi
            ;;
        *.ts|*.js)
            if [[ ! "$file" =~ \.test\. ]] && [[ ! "$file" =~ \.spec\. ]] && [[ ! "$file" =~ __tests__/ ]]; then
                basename=$(basename "$file" | sed 's/\.[^.]*$//')
                dir=$(dirname "$file")

                if [ ! -f "${dir}/${basename}.test.ts" ] && \
                   [ ! -f "${dir}/${basename}.test.js" ] && \
                   [ ! -f "${dir}/${basename}.spec.ts" ] && \
                   [ ! -f "${dir}/${basename}.spec.js" ] && \
                   [ ! -f "__tests__/${basename}.ts" ] && \
                   [ ! -f "__tests__/${basename}.js" ]; then
                    echo -e "${YELLOW}вљ пёЏ  No test file found for: $file${NC}"
                fi
            fi
            ;;
        *.py)
            if [[ ! "$file" =~ test_ ]] && [[ ! "$file" =~ _test\.py$ ]] && [[ ! "$file" =~ tests?/ ]]; then
                basename=$(basename "$file" .py)
                dir=$(dirname "$file")

                if [ ! -f "${dir}/test_${basename}.py" ] && \
                   [ ! -f "${dir}/${basename}_test.py" ] && \
                   [ ! -f "tests/test_${basename}.py" ]; then
                    echo -e "${YELLOW}вљ пёЏ  No test file found for: $file${NC}"
                fi
            fi
            ;;
        *.go)
            if [[ ! "$file" =~ _test\.go$ ]]; then
                basename=$(basename "$file" .go)
                dir=$(dirname "$file")

                if [ ! -f "${dir}/${basename}_test.go" ]; then
                    echo -e "${YELLOW}вљ пёЏ  No test file found for: $file${NC}"
                fi
            fi
            ;;
    esac
done

# Check 3: File integrity checks (large files, secrets)
echo -e "${BLUE}рџ“¦ Checking file integrity...${NC}"

for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        # Check file size
        FILE_SIZE=$(stat -f%z "$file" 2>/dev/null || stat -c%s "$file" 2>/dev/null || echo "0")
        if [ "$FILE_SIZE" -gt "$MAX_FILE_SIZE_BYTES" ]; then
            echo -e "${RED}вќЊ Large file detected: $file ($((FILE_SIZE / 1024 / 1024)) MB)${NC}"
            echo "   Files must be under $((MAX_FILE_SIZE_BYTES / 1024 / 1024)) MB"
            ERRORS=$((ERRORS + 1))
        fi

        # Check for secrets (only in text files)
        if file "$file" | grep -qE '(ASCII|UTF-8|text)'; then
            for pattern in "${SECRET_PATTERNS[@]}"; do
                if grep -qE "$pattern" "$file" 2>/dev/null; then
                    # Skip false positives in known test/example directories
                    case "$file" in
                        */test*|*/tests*|*/fixtures*|*/examples*|*/sample*)
                            continue ;;
                    esac
                    echo -e "${RED}вќЊ Possible secret detected in: $file${NC}"
                    echo "   Check: $pattern"
                    ERRORS=$((ERRORS + 1))
                fi
            done
        fi
    fi
done

# Check 4: Run formatting and linting based on project type
echo -e "${BLUE}рџЋЁ Running formatters and linters...${NC}"

RUST_FILES_RS=$(echo "$STAGED_FILES" | grep -E '\.rs$' || true)
RUST_MANIFEST_CHANGED=false
echo "$STAGED_FILES" | grep -qE '(Cargo\.toml|Cargo\.lock)$' && RUST_MANIFEST_CHANGED=true

# cargo fmt --check on any changed .rs files
if [ -n "$RUST_FILES_RS" ] && [ -f "Cargo.toml" ]; then
    echo "  Running cargo fmt --check..."
    if command -v cargo >/dev/null 2>&1; then
        CHANGED_DIRS=$(echo "$RUST_FILES_RS" | xargs -n1 dirname | sort -u)
        for dir in $CHANGED_DIRS; do
            if [ -f "$dir/Cargo.toml" ]; then
                if ! (cd "$dir" && cargo fmt --check 2>/dev/null); then
                    echo -e "${RED}вќЊ Formatting issues in: $dir${NC}"
                    echo "   Run: cargo fmt"
                    ERRORS=$((ERRORS + 1))
                fi
            fi
        done
    fi
fi

# cargo clippy on Cargo.toml/Cargo.lock changes (full workspace)
if [ "$RUST_MANIFEST_CHANGED" = true ] && [ -f "Cargo.toml" ]; then
    echo "  Running cargo clippy (manifest changed)..."
    if command -v cargo >/dev/null 2>&1; then
        if ! cargo clippy --all-targets -- -D warnings 2>/dev/null; then
            echo -e "${RED}вќЊ Clippy warnings/errors detected${NC}"
            echo "   Run: cargo clippy -- -D warnings"
            ERRORS=$((ERRORS + 1))
        fi
    fi
fi

# cargo clippy on changed .rs files (no manifest change вЂ” directory-local check)
if [ "$RUST_MANIFEST_CHANGED" = false ] && [ -n "$RUST_FILES_RS" ] && [ -f "Cargo.toml" ]; then
    echo "  Running cargo clippy on changed files..."
    if command -v cargo >/dev/null 2>&1; then
        CHANGED_DIRS=$(echo "$RUST_FILES_RS" | xargs -n1 dirname | sort -u)
        for dir in $CHANGED_DIRS; do
            if [ -f "$dir/Cargo.toml" ]; then
                if ! (cd "$dir" && cargo clippy --all-targets -- -D warnings 2>/dev/null); then
                    echo -e "${YELLOW}вљ пёЏ  Clippy warnings in: $dir${NC}"
                    # Non-blocking when only .rs files changed (manifest stable)
                fi
            fi
        done
    fi
fi

if [ -f "package.json" ]; then
    echo "  Running Prettier..."
    if command -v npx >/dev/null 2>&1 && [ -f "node_modules/.bin/prettier" ]; then
        PRETTIER_FILES=$(echo "$STAGED_FILES" | grep -E '\.(ts|tsx|js|jsx|json|md|yml|yaml)$' || true)
        if [ -n "$PRETTIER_FILES" ]; then
            if ! echo "$PRETTIER_FILES" | xargs npx prettier --check 2>/dev/null; then
                echo -e "${RED}вќЊ Prettier formatting issues${NC}"
                echo "   Run: npx prettier --write <files>"
                ERRORS=$((ERRORS + 1))
            fi
        fi
    fi
fi

if [ -f "pyproject.toml" ] || [ -f "setup.py" ]; then
    echo "  Running Ruff..."
    if command -v ruff >/dev/null 2>&1; then
        RUFF_FILES=$(echo "$STAGED_FILES" | grep -E '\.py$' || true)
        if [ -n "$RUFF_FILES" ]; then
            if ! echo "$RUFF_FILES" | xargs ruff check 2>/dev/null; then
                echo -e "${RED}вќЊ Ruff linting issues${NC}"
                echo "   Run: ruff check --fix <files>"
                ERRORS=$((ERRORS + 1))
            fi
        fi
    fi
fi

# Summary
if [ $ERRORS -eq 0 ]; then
    echo -e "${GREEN}вњ… Pre-commit checks passed!${NC}"
    exit 0
else
    echo -e "${RED}вќЊ Pre-commit checks failed with $ERRORS error(s)${NC}"
    echo "Fix the issues above or use --no-verify to skip (not recommended)"
    exit 1
fi
