{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Melosviz",
  "version": "0.1.0",
  "identifier": "ai.phenotype.melosviz",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Melosviz",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Music",
    "shortDescription": "Audio-driven visual spec",
    "longDescription": "Melosviz converts MIDI/audio input into a visual specification for music playback."
  }
}
