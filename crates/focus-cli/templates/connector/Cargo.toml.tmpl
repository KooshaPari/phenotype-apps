[package]
name = "connector-{{name}}"
version.workspace = true
edition.workspace = true
license.workspace = true
rust-version.workspace = true

[features]
default = []
{{#if keychain}}keychain = ["dep:focus-crypto", "dep:secrecy"]{{/if}}

[dependencies]
focus-connectors = { path = "../focus-connectors" }
focus-events = { path = "../focus-events" }
{{#if keychain}}focus-crypto = { path = "../focus-crypto", optional = true }
secrecy = { workspace = true, optional = true }{{/if}}
serde = { workspace = true }
serde_json = { workspace = true }
thiserror = { workspace = true }
anyhow = { workspace = true }
async-trait = { workspace = true }
reqwest = { workspace = true }
{{#if oauth2}}oauth2 = { workspace = true }{{/if}}
tokio = { workspace = true }
chrono = { workspace = true }
uuid = { workspace = true }
tracing = { workspace = true }

[dev-dependencies]
wiremock = "0.6"
tokio = { workspace = true }
serde_json = { workspace = true }
