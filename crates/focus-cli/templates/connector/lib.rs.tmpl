pub struct {{Name}}ConnectorBuilder {
    account_id: Uuid,
    http: Option<reqwest::Client>,
}

impl {{Name}}ConnectorBuilder {
    pub fn new() -> Self {
        Self {
            account_id: Uuid::nil(),
            http: None,
        }
    }

    pub fn account_id(mut self, id: Uuid) -> Self {
        self.account_id = id;
        self
    }

    pub fn http_client(mut self, client: reqwest::Client) -> Self {
        self.http = Some(client);
        self
    }

    pub fn build(self) -> {{Name}}Connector {
        let http = self.http.unwrap_or_default();
        let client = {{Name}}Client::new(http);
        let manifest = ConnectorManifest {
            name: "{{name}}".to_string(),
            version: env!("CARGO_PKG_VERSION").to_string(),
            tier: VerificationTier::Private,
            supported_auth: vec![AuthStrategy::{{auth_variant}}],
            supported_sync: vec![SyncMode::{{sync_variant}}],
        };
        {{Name}}Connector {
            manifest,
            account_id: self.account_id,
            client: Mutex::new(client),
        }
    }
}

impl Default for {{Name}}ConnectorBuilder {
    fn default() -> Self {
        Self::new()
    }
}

