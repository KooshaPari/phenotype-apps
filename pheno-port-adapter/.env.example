# OTLP-export tracing endpoint (ADR-036, T22.4).
# Read by the canonical `pheno-tracing` substrate when the OTLP pipeline
# is enabled. The substrate itself is initialised via
# `pheno_port_adapter::init()`; this endpoint is consumed by the OTLP
# exporter that `pheno-tracing` is wired to in production deployments.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
