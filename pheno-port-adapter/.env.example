# OTLP endpoint for pheno-port-adapter tracing (ADR-036, T22.4).
#
# pheno-tracing reads RUST_LOG for the filter directive (default
# `info`) and emits spans to stdout. The OTLP exporter is opt-in:
# point this variable at a collector to forward spans to OTLP.
# In-process init() does NOT bind an OTLP exporter itself; it sets
# up the tracing-subscriber that downstream OpenTelemetry layers
# (e.g. tracing-opentelemetry) layer on top of.
#
# Local dev (collector at localhost:4317):
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
