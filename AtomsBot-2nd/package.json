{
  "private": true,
  "name": "atomsbot",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "start": "node ./dist/index.js",
    "build": "rimraf dist && tsup",
    "build:bundle": "tsdown || tsc",
    "build:tsdown": "tsdown",
    "clean": "rimraf dist",
    "build:dev": "tsc --incremental",
    "deploy-commands": "node deploy-commands.js",
    "prune-global-commands": "tsx scripts/prune-global-commands.ts",
    "format": "prettier --write \"**/*.{json,ts}\"",
    "lint": "oxlint src api || true",
    "lint:fix": "oxlint --fix src api",
    "forward": "ssh -R 80:localhost:5000 serveo.net",
    "vercel-build": "npm run build",
    "vercel-dev": "vercel dev",
    "commands:register": "tsx src/discord/tools/register-commands.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:coverage:watch": "vitest --coverage",
    "test:coverage:ui": "vitest --ui --coverage",
    "test:unit": "vitest run --reporter=verbose src/**/*.test.{ts,js}",
    "test:integration": "vitest run --config=src/__tests__/integration/test-runner.config.ts --reporter=verbose src/**/*.integration.test.{ts,js}",
    "test:integration:watch": "vitest --config=src/__tests__/integration/test-runner.config.ts --reporter=verbose src/**/*.integration.test.{ts,js}",
    "test:integration:coverage": "vitest run --config=src/__tests__/integration/test-runner.config.ts --coverage --reporter=verbose src/**/*.integration.test.{ts,js}",
    "test:e2e": "vitest run --config=src/__tests__/integration/test-runner.config.ts --reporter=verbose src/**/*.e2e.test.{ts,js}",
    "test:workflows": "vitest run --config=src/__tests__/integration/test-runner.config.ts src/__tests__/integration/complete-issue-workflows.integration.test.ts src/__tests__/integration/end-to-end-workflows.integration.test.ts",
    "test:workflows:watch": "vitest --config=src/__tests__/integration/test-runner.config.ts src/__tests__/integration/complete-issue-workflows.integration.test.ts src/__tests__/integration/end-to-end-workflows.integration.test.ts",
    "test:all": "npm run test:coverage && node scripts/test-runner.js --all",
    "test:features": "node scripts/test-runner.js",
    "test:performance": "node scripts/test-runner.js --performance",
    "test:discord": "node scripts/test-runner.js --discord",
    "test:handlers": "node scripts/test-runner.js --handlers",
    "test:forms": "node scripts/test-runner.js --forms",
    "test:full": "node scripts/test-runner.js",
    "test:watch-runner": "node scripts/test-runner.js --watch",
    "test:lint": "node scripts/test-runner.js --lint",
    "test:typecheck": "node scripts/test-runner.js --typecheck",
    "test:phase1": "npx tsx src/discord/framework/tests/phase1-validation.ts",
    "test:phase2": "npx tsx src/discord/components/tests/simple-phase2-validation.ts",
    "test:phase3": "npx tsx src/discord/advanced/tests/phase3-validation.ts",
    "db:init": "tsx scripts/init-database.ts",
    "db:migrate": "tsx scripts/migrate-to-database.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:reset": "prisma db push --force-reset",
    "db:heal": "tsx src/maintenance/dbHeal.ts",
    "jira:groups": "tsx scripts/jira-list-groups.ts",
    "jira:group:members": "tsx scripts/jira-list-group-members.ts",
    "services:test": "tsx scripts/test-services.ts",
    "quick-start": "node scripts/quick-start.js",
    "setup": "npm run quick-start",
    "validate": "npm run test:all",
    "typecheck:core": "tsc -p tsconfig.check.json",
    "tunnel:add": "tsx scripts/tunnel-add.ts",
    "tunnel:down": "tsx scripts/tunnel-down.ts",
    "tunnel:status": "tsx scripts/tunnel-status.ts",
    "links:backfill": "tsx scripts/backfill-links.ts",
    "seed:teams": "tsx scripts/seed-teams.ts",
    "seed:scheduling": "tsx scripts/seed-scheduling.ts"
  },
  "author": "Nicat",
  "license": "MIT",
  "engines": {
    "node": ">=18",
    "bun": ">=1.0"
  },
  "dependencies": {
    "@octokit/graphql": "^7.1.0",
    "@octokit/rest": "^20.1.1",
    "@prisma/client": "^6.15.0",
    "@vercel/node": "^5.5.12",
    "axios": "^1.16.0",
    "better-sqlite3": "^12.2.0",
    "discord-interactions": "^4.3.0",
    "discord.js": "^14.26.0",
    "dotenv": "^16.4.5",
    "express": "^4.22.0",
    "googleapis": "^152.0.0",
    "ioredis": "^5.7.0",
    "jira.js": "^5.2.1",
    "luxon": "^3.7.1",
    "nats": "^2.29.3",
    "prisma": "^6.19.3",
    "undici": "^8.2.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^4.17.21",
    "@types/ioredis": "^4.28.10",
    "@types/node": "^24.3.0",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "bufferutil": "^4.0.8",
    "eslint-config-prettier": "^9.1.0",
    "happy-dom": "^20.9.0",
    "oxlint": "^1.13.0",
    "prettier": "^3.3.2",
    "rimraf": "^6.1.1",
    "rolldown-vite": "^7.3.1",
    "supertest": "^7.1.4",
    "tsdown": "^0.14.2",
    "tsup": "^8.5.1",
    "tsx": "^4.15.4",
    "typescript": "^5.9.2",
    "utf-8-validate": "^6.0.4",
    "vite": "^8.0.10",
    "vite-tsconfig-paths": "^5.0.1",
    "vitest": "^4.1.5"
  },
  "packageManager": "bun@1"
}
