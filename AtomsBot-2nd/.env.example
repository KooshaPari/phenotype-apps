## Core Discord
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_client_id
# Optional: faster command registration during dev
DISCORD_DEV_GUILD_ID=
# Default forum channel (used for initial tag caching)
DISCORD_CHANNEL_ID=123456789012345678

## GitHub (required for full feature)
GITHUB_ACCESS_TOKEN=your_github_pat
GITHUB_USERNAME=your_github_owner
GITHUB_REPOSITORY=your_repo

## Project Management Provider
# Options: jira | linear | github_projects | coda
PM_PROVIDER=jira
# Enable cross-platform sync mirroring (e.g., mirror to Coda)
PM_SYNC=false
# Per-provider sync overrides (optional)
PM_SYNC_JIRA=
PM_SYNC_LINEAR=
PM_SYNC_GITHUB_PROJECTS=
PM_SYNC_CODA=

# Sync Engine (optional background checker)
PM_SYNC_ENGINE_ENABLED=true
PM_SYNC_ENGINE_INTERVAL_MS=300000

## Linear (optional, if PM_PROVIDER=linear)
LINEAR_API_KEY=
# Optional scoping
LINEAR_TEAM_ID=
LINEAR_PROJECT_ID=

## GitHub Projects (optional, if PM_PROVIDER=github_projects)
# Reuses GITHUB_ACCESS_TOKEN
GITHUB_PROJECTS_ORG=
# Provide either NUMBER (preferred) or ID
GITHUB_PROJECTS_NUMBER=
GITHUB_PROJECTS_ID=

## Jira (required for full feature)
JIRA_HOST=your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=PROJ
JIRA_SPRINT_FIELD=customfield_10020
# Optional transitions (leave blank to auto-detect)
JIRA_TRANSITION_CLOSE=
JIRA_TRANSITION_DONE=
JIRA_TRANSITION_WONT_DO=
JIRA_TRANSITION_REOPEN=

## Coda (optional, for PM_PROVIDER=coda or when PM_SYNC=true for mirroring)
CODA_API_TOKEN=
CODA_DOC_ID=
# Optional table/column mapping for issues/comments
CODA_ISSUES_TABLE_ID=
CODA_COMMENTS_TABLE_ID=
CODA_USERS_TABLE_ID=
CODA_ISSUE_KEY_COLUMN=Key
CODA_ISSUE_TITLE_COLUMN=Title
CODA_ISSUE_STATUS_COLUMN=Status
CODA_ISSUE_PRIORITY_COLUMN=Priority
CODA_ISSUE_ASSIGNEE_COLUMN=Assignee
CODA_ISSUE_UPDATED_AT_COLUMN=Updated At

## Database (SQLite)
DATABASE_URL="file:./prisma/data/bot.db"
# Optional: shadow JSON ↔ DB writes
PERSISTENCE_DB_ENABLED=false

## Server
PORT=3000

## Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/auth/callback
GCAL_PRIMARY_CALENDAR_ID=primary
GOOGLE_ENABLE_DRIVE_READONLY=false
ATOMS_KEYWORDS=atoms,atoms.tech
GOOGLE_WEBHOOK_ADDRESS=
REMINDER_OFFSETS=15,5

# Permissions
MEETING_CREATE_ALLOWED_USER_IDS=

# Note: Prefer managing credentials via Discord commands:
# Note: Prefer managing credentials via Discord commands:
# - /setup secrets set … (GitHub/Jira)
# - /setup google set … (Google OAuth/Calendar)
# - /setup vercel set … (Vercel)
# - /setup pm set provider:<jira|linear|github_projects|coda> sync:<true|false>
# - /setup coda set … (Coda token, doc and mappings)

# (deprecated duplicate section kept for backward-compat)
