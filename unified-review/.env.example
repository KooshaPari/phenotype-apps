# ============================================================================
# Unified Review — Environment Variables
# ============================================================================

# --- GitHub App credentials (REQUIRED for production) ---
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=

# --- Organization (used as quota scope) ---
GITHUB_ORG=your-org

# --- Redis (optional; falls back to in-memory) ---
# REDIS_URL=redis://localhost:6379

# --- Posting mode ---
# Options: "checks_api" (default), "pr_review", "both"
POSTING_MODE=checks_api

# --- Forge (local runner) ---
# Set OMNIROUTE_URL if using a remote OmniRoute dispatch
OMNIROUTE_URL=http://localhost:20128
FORGE_BIN=forge

# --- Cloud tool credentials (optional) ---
COPILOT_API_TOKEN=
CODERABBIT_API_TOKEN=
CURSOR_API_TOKEN=
KILOCODE_API_TOKEN=
