# Helm
charts/*/charts/
charts/*/requirements.lock

# Local scripts
scripts/local/
scripts/*.local.*
/worktrees/
/*-wtrees/

# Lowercase justfile is a duplicate of canonical Justfile (uppercase).
# Both are kept on disk for `just` CLI compatibility, but only the
# uppercase version is tracked. Added 2026-06-20 to silence
# 'Untracked files' warnings in `git status`.
/justfile
!/Justfile

# Router binary (spike build artifact, never committed)
/_check

# AgilePlus local state (local DBs and trash from external sessions)
# (pattern added 2026-06-21 — these are local-only, regenerated by `agileplus` CLI)
/.agileplus/

# External-session trash dirs (transient worktrees / pre-trash snapshots)
/.trash-*/

# Local SPIRE/cosign scratch (workload identity, never committed)
/.workload-identity/
/.cosign-key/

# Per-repo dev workspaces (worktree containers that should never be committed)
